{
  "name": "spectral-curiosity",
  "private": false,
  "version": "0.1.0",
  "description": "Backup, sync, and manage Antigravity conversations",
  "author": "kno-raziel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kno-raziel/spectral-curiosity"
  },
  "homepage": "https://github.com/kno-raziel/spectral-curiosity#readme",
  "bugs": {
    "url": "https://github.com/kno-raziel/spectral-curiosity/issues"
  },
  "bin": {
    "spectral-curiosity": "./src/server/index.ts"
  },
  "files": [
    "dist/*.js",
    "dist/*.css",
    "dist/*.html",
    "dist/*.svg",
    "src/server",
    "src/shared",
    "src/client",
    "index.html"
  ],
  "keywords": [
    "antigravity",
    "ai-conversations",
    "backup",
    "data-portability",
    "vscode-extension",
    "bun",
    "react",
    "workspace-manager"
  ],
  "type": "module",
  "scripts": {
    "prepublishOnly": "bun run build",
    "dev": "bunx @tailwindcss/cli -i src/client/index.css -o dist/app.css --watch & bun run --watch src/server/index.ts",
    "build": "bunx @tailwindcss/cli -i src/client/index.css -o dist/app.css --minify && bun build ./index.html --production --outdir=dist",
    "build:ext": "cd src/extension && npm install && node esbuild.mjs",
    "build:bin": "bun build --compile --minify --define 'IS_BUN_COMPILE=true' ./src/server/index.ts --outfile dist/spectral",
    "watch:ext": "cd src/extension && node esbuild.mjs --watch",
    "package:ext": "bun run build:ext && cd src/extension && npx @vscode/vsce package",
    "deploy:ext": "bun run package:ext && antigravity --install-extension src/extension/spectral-extension-0.1.0.vsix --force",
    "release": "changelogen --release --push",
    "release:dry": "changelogen",
    "check": "bun run typecheck && bun run lint",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "^1.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "changelogen": "^0.6.2",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3"
  }
}
